<footer>
    <p>&copy; 2025–2026 <a href="https://www.robertocalvoproductions.com">ROBERTO CALVO PRODUCTIONS LTD</a>. All rights reserved.</p>
    <p style="margin-top:4px;">Sigillum Maximum &mdash; The Seal of the Seven Secrets by Eleanor Lian</p>
</footer>

<!-- ==================== MODAL ==================== -->
<div class="modal-overlay" id="modalOverlay">
    <div class="modal" id="modalContent">
        <button class="modal-close" onclick="closeModal()">✕</button>
        <img id="modalImg" src="" alt="">
        <h2 id="modalName"></h2>
        <div class="role" id="modalRole"></div>
        <p id="modalDesc"></p>
    </div>
</div>

<script>
const characters = [
    { name: 'Aileen', role: 'Protagonist', image: 'images/Aileen ragazzina, 13 anni.png', desc: 'The Princess of Nuvolandia. At thirteen, she witnesses the destruction of her kingdom and is thrust into a perilous quest across the Seven Realms. Brave, compassionate, and determined, Aileen carries the weight of an entire world on her shoulders as she grows from a sheltered girl into a young leader.' },
    { name: 'Dorcha', role: 'The Knight with Darkness in His Blood', image: 'images/2. Dorcha, cavaliere nero.png', desc: 'Mysterious and conflicted, Dorcha was raised by orcs but carries a darkness that may be the key — or the doom — of the Great Universal Realm. His bond with Aileen grows into something neither expected, something that may defy fate itself.' },
    { name: 'Grogher', role: 'The Fierce Orc with a Golden Heart', image: 'images/Grogher 2.png', desc: 'An orc of immense strength and even greater loyalty. Separated from his family at birth, Grogher finds a new purpose in protecting Aileen. With his winged lion Sidae by his side, he proves that courage comes in all shapes.' },
    { name: 'Aeltiàfisar', role: 'Knight of the Golden Light', image: '', icon: '🗡️', desc: 'The legendary elven knight who once rode dragons into battle. Ancient, wise, and carrying the sorrow of a lost love, Aeltiàfisar becomes Aileen\'s guide and mentor — the bridge between her childhood and her destiny. Awaiting his official artwork.' },
    { name: 'Raertha', role: 'Aileen\'s Magical Companion', image: 'images/Raertha.jpg', desc: 'A winged white unicorn of incredible beauty and power. Gifted to Aileen by King Baelkers, Raertha is a healer whose magic can mend the deepest wounds — physical and emotional.' },
    { name: 'Sidae', role: 'Grogher\'s Companion', image: 'images/Raertha Hercules e Sidae.jpg', desc: 'An immense winged white lion who can read the hearts of those around him. Sidae never abandons Grogher, offering loyalty, warmth, and an approving purr when he senses a pure soul.' },
    { name: 'Hercules', role: 'Dorcha\'s Steed', image: 'images/Hercules.jpg', desc: 'Dorcha\'s loyal black horse, later gifted the power of flight. Hercules is steadfast, perceptive, and responds to the emotional currents of his companions.' },
    { name: 'Princess Majory', role: 'Gnome Princess', image: 'images/Majory.png', desc: 'The Princess of the Gnome Kingdom. Competitive, caring, and impulsive, Majory discovers that an ancient curse upon her family demands the ultimate sacrifice — and that true courage means choosing love over survival.' },
    { name: 'Asher', role: 'True Love', image: 'images/Asher.png', desc: 'A gentle gnome tailor with a pure heart. Asher falls deeply in love with Majory and is willing to give everything — even his own life — to save her from the ancient curse.' },
    { name: 'King Eadwig', role: 'King of Nuvolandia', image: 'images/3. Lotta tra Eadwig e Dorcha.png', desc: 'Aileen\'s father, the proud King of Nuvolandia. Turned to stone by the Black Knight\'s dark magic, his fate drives Aileen\'s quest to recover the Sigillum Maximum.' },
    { name: 'Queen Eloria', role: 'Queen of Nuvolandia', image: 'images/5. Aileen ed Eloria si incontrano.png', desc: 'Aileen\'s mother. Transformed into a statue by the Black Knight, she is a symbol of everything Aileen fights to restore.' },
    { name: 'Helbert', role: 'Royal Advisor', image: 'images/Helbert.png', desc: 'The goblin royal advisor of Nuvolandia. Loyal, sharp-witted, and deeply devoted to the royal family, Helbert helps guide Aileen through her first steps into the unknown.' },
    { name: 'King Baelkers', role: 'Elf King', image: 'images/Re Bàistec.png', desc: 'The wise and powerful king of the Elves. A former companion of Aeltiàfisar in the ancient wars, he gifts Aileen her winged unicorn Raertha and becomes a steadfast ally.' },
    { name: 'Aer', role: 'Aeltiàfisar\'s Lost Love', image: 'images/10. Aileen corre verso il castello.png', desc: 'A human girl who became a cloud spirit, then the wife of Aeltiàfisar. Her tragic death in a night attack set in motion events that echo through the ages.' },
];

function renderCharacters() {
    const grid = document.getElementById('charactersGrid');
    grid.innerHTML = '';
    characters.forEach((ch, i) => {
        const card = document.createElement('div');
        card.className = 'character-card';
        card.innerHTML = `
            ${ch.image ? `<img src="${ch.image}" alt="${ch.name}" loading="lazy" onerror="this.parentElement.style.display='none'">` : `<div style="height:260px;display:flex;align-items:center;justify-content:center;background:rgba(212,167,71,0.05);font-size:4rem;opacity:0.5;">${ch.icon || '✨'}</div>`}
            <div class="character-info">
                <h4>${ch.name}</h4>
                <div class="role">${ch.role}</div>
                <div class="desc">${ch.desc.substring(0, 80)}${ch.desc.length > 80 ? '...' : ''}</div>
            </div>
        `;
        card.addEventListener('click', () => openModal(ch, i));
        grid.appendChild(card);
    });
}

function openModal(ch, i) {
    const overlay = document.getElementById('modalOverlay');
    overlay.classList.add('active');
    const modalImg = document.getElementById('modalImg');
    if (ch.image) {
        modalImg.src = ch.image;
        modalImg.style.display = 'block';
    } else {
        modalImg.style.display = 'none';
    }
    document.getElementById('modalName').textContent = ch.name;
    document.getElementById('modalRole').textContent = ch.role;
    document.getElementById('modalDesc').textContent = ch.desc;
    document.body.style.overflow = 'hidden';
}

function closeModal() {
    document.getElementById('modalOverlay').classList.remove('active');
    document.body.style.overflow = '';
}

document.addEventListener('DOMContentLoaded', renderCharacters);

// Navbar scroll effect
const navbar = document.getElementById('navbar');
window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 100);
});

// Mobile nav toggle
document.getElementById('navToggle').addEventListener('click', () => {
    document.getElementById('navLinks').classList.toggle('active');
});

// Close mobile nav on link click
document.querySelectorAll('.nav-links a').forEach(link => {
    link.addEventListener('click', () => {
        document.getElementById('navLinks').classList.remove('active');
    });
});

// Close modal on overlay click
document.getElementById('modalOverlay').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeModal();
});

// Escape key closes modal
document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
});
</script>
</body>
</html>
